datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
model Task {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  startAt     DateTime 
  endAt       DateTime 
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startAt])
}